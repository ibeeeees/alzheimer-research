---

<Base title="Alzheimer Detection from Speech">

  <nav>
    <div class="nav-inner">
      <span class="nav-title">AD Speech Detection</span>
      <div class="nav-links">
        <a href="#problem">Problem</a>
        <a href="#method">Method</a>
